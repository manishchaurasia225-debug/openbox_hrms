# =============================================================================
# OGM HRMS — Environment configuration template
# =============================================================================
# Quick start:
#     cp .env.example .env      # (.env.dev also works and takes precedence)
#     # edit the values below (at minimum DB_* and the SUPER_ADMIN_* block)
#     ./scripts/run-dev.sh
#
# The run scripts load this file with `set -a; source ...; set +a`, so every
# variable here is exported and picked up by Spring via application*.yaml.
# Because it is loaded via `source`, any value containing spaces or special
# characters MUST be quoted (e.g. FOO="a b c").
# `.env*` files are git-ignored except this example — never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
# Active Spring profile: dev | prod  (dev is the default if unset).
SPRING_PROFILES_ACTIVE=dev

# HTTP port the app listens on.
SERVER_PORT=8080

# -----------------------------------------------------------------------------
# Database (PostgreSQL) — REQUIRED
# -----------------------------------------------------------------------------
# JDBC URL, username, and password for the HRMS database.
# Create the database first, e.g.:  createdb hrms   (see README).
DB_URL=jdbc:postgresql://localhost:5432/hrms
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME

# Hibernate schema strategy. Flyway owns the schema, so this stays `validate`
# (Hibernate only checks entities match the migrated tables). dev may use
# `update` for throwaway spikes; NEVER use `update`/`create` in prod.
JPA_DDL_AUTO=validate

# Connection pool bounds (mainly relevant to the prod profile).
DB_POOL_MAX=10
DB_POOL_MIN=2

# -----------------------------------------------------------------------------
# Security — JWT — REQUIRED in staging/prod
# -----------------------------------------------------------------------------
# HMAC signing secret for JWTs. MUST be >= 32 bytes. The dev profile ships an
# insecure fallback so the app boots without this — leave it COMMENTED OUT for
# local dev. Outside dev it is REQUIRED; uncomment and set a real secret.
# IMPORTANT: an empty value here is NOT the same as unset — it OVERRIDES the dev
# fallback with a blank secret and the app will refuse to start. Leave it
# commented rather than assigning it an empty string.
# Generate one with:  openssl rand -base64 48
#HRMS_JWT_SECRET=
# Access/refresh token lifetimes (ISO-8601 durations).
HRMS_JWT_ACCESS_TTL=PT15M
HRMS_JWT_REFRESH_TTL=P7D

# Account lockout after repeated failed logins.
HRMS_LOCKOUT_MAX_ATTEMPTS=5
HRMS_LOCKOUT_DURATION=PT15M

# Password-reset / email-verification token lifetimes (ISO-8601 durations).
HRMS_PASSWORD_RESET_TTL=PT30M
HRMS_EMAIL_VERIFICATION_TTL=P1D

# CORS — browser origins allowed to call /api/**. Comma-separated; leave EMPTY to
# grant no cross-origin access (safe default). The dev profile already allows the
# local SPA dev servers (http://localhost:5173, http://localhost:3000); set this
# to your real web host(s) in staging/prod. Never combine "*" with credentials.
HRMS_CORS_ALLOWED_ORIGINS=
# Set true only if the browser must send cookies/credentials cross-origin (Bearer
# token auth does not require it). Must NOT be true together with a "*" origin.
HRMS_CORS_ALLOW_CREDENTIALS=false

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Base URL used to build links (password reset, email verification) in emails.
HRMS_APP_BASE_URL=http://localhost:8080

# Local filesystem path where uploaded document binaries are stored, and the
# per-file size cap in bytes (S3 backend is pluggable later).
HRMS_STORAGE_PATH=storage/documents
HRMS_STORAGE_MAX_BYTES=10485760

# Multipart upload limits.
HRMS_MAX_FILE_SIZE=10MB
HRMS_MAX_REQUEST_SIZE=12MB

# Actuator endpoints to expose over HTTP (health + info by default).
MANAGEMENT_ENDPOINTS=health,info

# -----------------------------------------------------------------------------
# Initial Super Admin bootstrap (FIRST-RUN ONLY)
# -----------------------------------------------------------------------------
# The application seeds NO users by default. On first startup, if BOTH values
# below are set AND no user with this email exists yet, a single Super Admin
# account is created so you can log in. Login is by email (there is no separate
# username). If either value is blank, no admin is created and you must seed one
# before you can authenticate.
#
#   - Used ONLY to bootstrap the initial Super Admin on first startup when the
#     account does not yet exist.
#   - After that Super Admin exists, these values are IGNORED on every
#     subsequent startup (the bootstrap is idempotent — it never re-applies).
#   - These MUST NEVER contain production credentials. The placeholders below
#     are for local development only.
#   - Production deployments MUST override these via real environment variables
#     or a secrets manager — never commit real values to any file.
#   - The password is stored BCrypt-hashed; it is never persisted in plaintext.
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
# Optional display name for the bootstrapped admin (defaults to "System Administrator").
# NOTE: values containing spaces MUST be quoted — this file is loaded via `source`.
SUPER_ADMIN_FULL_NAME="System Administrator"

# -----------------------------------------------------------------------------
# Email / SMTP — OPTIONAL
# -----------------------------------------------------------------------------
# By default NO SMTP server is configured, so outgoing emails (password reset,
# verification, payslips) are LOGGED instead of sent — which is fine for local
# dev. To send real email, configure spring.mail.* in your own config; these
# placeholders document the values you'd supply. Leaving them unset keeps the
# safe log-only behaviour.
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=

# -----------------------------------------------------------------------------
# NOT YET ACTIVE (reserved for future modules — leaving these set does nothing)
# -----------------------------------------------------------------------------
# Redis caching and AWS S3 document storage are on the roadmap but not wired
# into the running application yet. Do not rely on these having any effect.
# REDIS_HOST=localhost
# REDIS_PORT=6379
# AWS_S3_BUCKET=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
